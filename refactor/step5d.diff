+### Access Port Example
+
+```python
+from napalm_jtcom.driver import JTComDriver
+from napalm_jtcom.model.config import DeviceConfig
+from napalm_jtcom.model.port import PortConfig
+
+driver = JTComDriver("192.0.2.1", "admin", "secret", optional_args={"verify_tls": False})
+driver.open()
+
+try:
+    result = driver.apply_device_config(
+        DeviceConfig(
+            ports={
+                3: PortConfig(
+                    port_id=3,
+                    access_vlan=20,
+                ),
+            },
+        ),
+        check_mode=True,
+    )
+    print(result["warnings"])
+finally:
+    driver.close()
+```
+
+### Trunk Port Example
+
+```python
+from napalm_jtcom.driver import JTComDriver
+from napalm_jtcom.model.config import DeviceConfig
+from napalm_jtcom.model.port import PortConfig
+
+driver = JTComDriver("192.0.2.1", "admin", "secret", optional_args={"verify_tls": False})
+driver.open()
+
+try:
+    result = driver.apply_device_config(
+        DeviceConfig(
+            ports={
+                5: PortConfig(
+                    port_id=5,
+                    native_vlan=10,
+                    trunk_set_vlans=[20, 30],
+                ),
+            },
+        ),
+        check_mode=True,
+    )
+    print(result["diff"])
+finally:
+    driver.close()
+```
+
